{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "DivaZaap",
  "outputfilename": "DivaZaap",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {
    "name": "Jordan Rey",
    "email": "rey.jordan.1998@gmail.com"
  },
  "info": {
    "companyName": "Diva",
    "productName": "DivaZaap",
    "productVersion": "0.0.1",
    "copyright": "Copyright 2024 - Diva",
    "comments": "A Go app made with Wails to emulate the Zaap Apache Thrift protocol"
  },
  "bindings": {
    "ts_generation": {
      "prefix": "Go",
      "outputType": "classes"
    }
  }
}
